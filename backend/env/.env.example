# ==================================
# 开发环境配置文件模版
# 复制此文件为 .env.dev 并修改配置
# ==================================

ENVIRONMENT="dev"

# 服务器配置
SERVER_HOST="localhost"     # 允许访问的IP地址
SERVER_PORT=8000          # 服务端口

# 文档配置
DEBUG=True                        # 调试模式
TITLE="🎉 AnyVid AI 🎉 -dev"    # 文档标题
VERSION = "0.1.0"                   # 版本号
SUMMARY = "接口汇总"                 # 文档概述
ROOT_PATH = "/api"               # API路由前缀
DESCRIPTION = "基于 yt-dlp 的万能视频下载服务，支持 1800+ 平台"  # 文档描述

# 是否启用演示模式
DEMO_ENABLE = False

# 数据库配置
DATABASE_TYPE = "mysql"  # mysql、postgres、sqlite、dm(sqlite、dm不支持代码生成)

# 数据库配置
DATABASE_HOST = "localhost"
DATABASE_PORT = 3306  # MySQL:3306 PostgreSQL:5432
DATABASE_USER = "root"
DATABASE_PASSWORD = "123456"
DATABASE_NAME = "anyvidai"

# 日志配置
LOGGER_LEVEL = "DEBUG"   # 日志级别

# DeepSeek AI API Key（已有）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Stripe 支付配置
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_ID_MONTHLY=price_your_monthly_price_id

# 前端 URL（用于 Stripe 支付回跳）
FRONTEND_URL=http://localhost:5173
